{
  "expo": {
    "name": "Parachi",
    "slug": "Parachi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "parachi",

    // Force light UI so Android/iOS don't apply dark-mode tinting to launch/splash
    "userInterfaceStyle": "light",

    "newArchEnabled": true,

    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fdc500"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.salarmiirzapour.Parachi",
      "deploymentTarget": "15.1",
      "infoPlist": {
        "NSCameraUsageDescription": "به برنامه اجازه دسترسی به دوربین را بدهید تا بتوانید عکس بگیرید و آپلود کنید.",
        "NSPhotoLibraryUsageDescription": "به برنامه اجازه دسترسی به عکس‌های شما را بدهید تا بتوانید فایل آپلود کنید.",
        "NSMicrophoneUsageDescription": "برای ضبط ویدیو نیاز به دسترسی میکروفون داریم"
      }
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#fdc500",
        "foregroundImage": "./assets/images/favicon.png"
      },

      // Keep a solid yellow behind the splash/launch on Android
      "splash": {
        "resizeMode": "contain",
        "backgroundColor": "#fdc500",
        "image": "./assets/images/splash-icon.png"
      },

      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.salarmiirzapour.Parachi",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fdc500",

          // Keep dark config same yellow too (even though we force light mode)
          "dark": {
            "backgroundColor": "#fdc500",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "به برنامه اجازه دسترسی به عکس‌های شما را بدهید تا بتوانید فایل آپلود کنید.",
          "cameraPermission": "به برنامه اجازه دسترسی به دوربین را بدهید تا بتوانید عکس بگیرید.",
          "microphonePermission": "برای ضبط ویدیو نیاز به دسترسی میکروفون داریم"
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-file-system",
        {
          "fileSystem": {
            "read": true,
            "write": true
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "minSdkVersion": 24,
            "targetSdkVersion": 35,
            "compileSdkVersion": 35,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
